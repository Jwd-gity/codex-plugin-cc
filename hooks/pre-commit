#!/usr/bin/env bash
# pre-commit hook: validate SKILL.md front matter before commit

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
validator="$repo_root/scripts/validate-skills"

if [[ -x "$validator" ]]; then
  # Only run if any SKILL.md files are staged
  staged_skills=$(git diff --cached --name-only --diff-filter=ACMR | grep 'SKILL\.md$' || true)
  if [[ -n "$staged_skills" ]]; then
    echo "Running skill validation..."
    "$validator"
  fi
fi
